# Variables d'environnement pour les tests E2E ortho.ia.
# Copier vers `.env.test` (gitignored) et remplir avec un compte Supabase
# dédié aux tests (NE PAS utiliser un compte ortho réelle).
#
# Le compte doit avoir un quota CRBO suffisant pour la suite de tests
# (1 run par fixture = 1 CRBO consommé sur le compteur mensuel).

E2E_BASE_URL=http://localhost:3000
E2E_TEST_EMAIL=test-e2e@ortho-ia.test
E2E_TEST_PASSWORD=changez-moi-en-local
