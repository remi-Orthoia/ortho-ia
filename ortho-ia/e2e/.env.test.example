# Variables d'environnement pour les tests E2E ortho.ia.
# Copier vers `.env.test` (gitignored) et remplir avec le mot de passe.
#
# Le compte demo@ortho-ia.fr est celui utilisé pour les tests manuels
# du founder. Son profil est rempli et son quota CRBO est étendu.

E2E_BASE_URL=http://localhost:3000
E2E_TEST_EMAIL=demo@ortho-ia.fr
E2E_TEST_PASSWORD=mets-ici-le-mot-de-passe-du-compte-demo
